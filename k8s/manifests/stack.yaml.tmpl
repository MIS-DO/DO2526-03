---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: search-api-ingress-prod
  namespace: ${PROD_NAMESPACE}
spec:
  ingressClassName: nginx
  rules:
    - http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: search-api
                port:
                  number: 80
