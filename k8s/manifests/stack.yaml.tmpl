apiVersion: v1
kind: Namespace
metadata:
  name: ${PREPROD_NAMESPACE}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: songs-mongo-pvc
  namespace: ${PREPROD_NAMESPACE}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: ${MONGO_STORAGE_SIZE}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: movies-mongo-pvc
  namespace: ${PREPROD_NAMESPACE}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: ${MONGO_STORAGE_SIZE}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: football-mongo-pvc
  namespace: ${PREPROD_NAMESPACE}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: ${MONGO_STORAGE_SIZE}
---
apiVersion: v1
kind: Service
metadata:
  name: songs-mongo
  namespace: ${PREPROD_NAMESPACE}
spec:
  type: ClusterIP
  selector:
    app: songs-mongo
  ports:
    - name: mongo
      port: 27017
      targetPort: 27017
---
apiVersion: v1
kind: Service
metadata:
  name: movies-mongo
  namespace: ${PREPROD_NAMESPACE}
spec:
  type: ClusterIP
  selector:
    app: movies-mongo
  ports:
    - name: mongo
      port: 27017
      targetPort: 27017
---
apiVersion: v1
kind: Service
metadata:
  name: football-mongo
  namespace: ${PREPROD_NAMESPACE}
spec:
  type: ClusterIP
  selector:
    app: football-mongo
  ports:
    - name: mongo
      port: 27017
      targetPort: 27017
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: songs-mongo
  namespace: ${PREPROD_NAMESPACE}
  labels:
    app: songs-mongo
spec:
  replicas: 1
  selector:
    matchLabels:
      app: songs-mongo
  template:
    metadata:
      labels:
        app: songs-mongo
    spec:
      containers:
        - name: mongo
          image: ${MONGO_IMAGE}
          ports:
            - containerPort: 27017
          resources:
            requests:
              cpu: ${MONGO_REQUEST_CPU}
              memory: ${MONGO_REQUEST_MEMORY}
            limits:
              cpu: ${MONGO_LIMIT_CPU}
              memory: ${MONGO_LIMIT_MEMORY}
          volumeMounts:
            - name: mongo-data
              mountPath: /data/db
      volumes:
        - name: mongo-data
          persistentVolumeClaim:
            claimName: songs-mongo-pvc
